# Copy to .env and fill in real values
APP_ENV=development
APP_NAME=offline-sewa
SECRET_KEY=change_me_in_production
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://sewa:sewa@db:5432/offline_sewa
DATABASE_URL_SYNC=postgresql://sewa:sewa@db:5432/offline_sewa

# Postgres (used by docker-compose)
POSTGRES_USER=sewa
POSTGRES_PASSWORD=sewa
POSTGRES_DB=offline_sewa

# SMS Provider
SMS_PROVIDER=sparrow
SPARROW_API_KEY=your_api_key_here
SPARROW_SENDER_ID=Demo
